# Railway Environment Variables
# Kopiere diese Datei zu .env und fülle die Werte aus

# Database
DATABASE_URL=postgresql://user:password@host:5432/lashesbylia

# Session
SESSION_SECRET=dein-geheimer-session-schluessel-min-32-zeichen

# Environment
NODE_ENV=production
PORT=3000

# SMTP E-Mail (optional – ohne diese Variablen werden E-Mails nur in der Konsole geloggt)
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_USER=noreply@lashes-by-lia.de
SMTP_PASS=dein-smtp-passwort
SMTP_FROM=Lashes by Lia <noreply@lashes-by-lia.de>

# App URL (für Passwort-Reset-Links)
APP_URL=https://lashes-by-lia.de
